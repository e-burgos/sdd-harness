{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "analytics": false,
  "workspaceLayout": {
    "appsDir": "apps",
    "libsDir": "libs"
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "production": [
      "default",
      "!{projectRoot}/.eslintrc.json",
      "!{projectRoot}/eslint.config.mjs",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json"
    ],
    "sharedGlobals": []
  },
  "plugins": [
<% nx.plugins.forEach(function(p, i) { var isLast = i === nx.plugins.length - 1; %>
<% if (p === '@nx/gradle') { %>    {
      "plugin": "@nx/gradle",
      "include": ["apps/**/*"],
      "options": {
        "testTargetName": "test",
        "ciTestTargetName": "test-ci"
      }
    }<%= isLast ? '' : ',' %>
<% } else { %>    { "plugin": "<%= p %>" }<%= isLast ? '' : ',' %>
<% } %>
<% }) %>  ],
  "defaultProject": "<%= nx.defaultProject || apps[0]?.name || 'app' %>"
}
